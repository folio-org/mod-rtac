      <url>https://repository.folio.org/repository/maven-snapshots/</url>
    </snapshotRepository>
  </distributionManagement>
  <properties>
    <http.port>8081</http.port>
    <java.version>21</java.version>
    <ramlfiles_path>${basedir}/ramls</ramlfiles_path>
